GEMINI_API_KEY=

# Optional: comma-separated list of keys for automatic fallback when one
# hits a free-tier rate limit (e.g. keys from a few teammates' accounts).
# If set, this takes priority over the single GEMINI_API_KEY above.
GEMINI_API_KEYS=

# Optional override if the default model name ever errors out.
# Check the current model list at https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-flash-latest
#npx localtunnel --port 3000